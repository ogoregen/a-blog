---
import BaseLayout from './BaseLayout.astro';

const { title, subtitle } = Astro.props;
---

<BaseLayout>
	<div class="">
		<h1 class="fly-margin-small-bottom a-title">{title}</h1>
		{subtitle && <div class="fly-text-muted a-subtitle">{subtitle}</div>}
	</div>
	<div class="fly-margin-large-top">
		<slot />
	</div>
</BaseLayout>
